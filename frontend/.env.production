# ============================================================================
# Production Environment Variables
# ============================================================================
# These variables are used when building for production (npm run build)
# Replace the placeholder URLs with your actual deployed backend URL

# API URL for production (HTTPS required)
# Example for Render.com: https://product-search-backend.onrender.com
# Example for custom domain: https://api.yourdomain.com
VITE_API_URL=https://your-backend.onrender.com

# WebSocket URL for production (WSS - secure WebSocket required)
# Example for Render.com: wss://product-search-backend.onrender.com/ws/notifications
# Example for custom domain: wss://api.yourdomain.com/ws/notifications
VITE_WS_URL=wss://your-backend.onrender.com/ws/notifications

# ============================================================================
# IMPORTANT: Update these URLs before deploying to production!
# ============================================================================
# 1. Deploy your backend to Render.com (or other hosting)
# 2. Copy the backend URL (e.g., https://product-search-backend.onrender.com)
# 3. Replace "your-backend.onrender.com" with your actual backend URL
# 4. For WebSocket, use wss:// instead of https://
# 5. Rebuild frontend: npm run build
# 6. Deploy frontend with updated environment variables