# Production environment variables for Render.com deployment
# Update these URLs after deploying to Render

# Backend API URL (update with your actual Render backend URL)
VITE_API_BASE_URL=https://product-search-agent-api.onrender.com

# WebSocket URL (update with your actual Render backend URL)
VITE_WS_URL=wss://product-search-agent-api.onrender.com/ws/notifications