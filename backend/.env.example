# ============================================================================
# Product Search Agent - Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env to version control!

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=Product Search Agent
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
ENVIRONMENT=development

# ============================================================================
# Server Configuration
# ============================================================================
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

# ============================================================================
# Database Settings
# ============================================================================
# SQLite (default for development)
DATABASE_URL=sqlite:///./product_search.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/product_search

DATABASE_ECHO=false

# ============================================================================
# Redis Configuration (Optional - for caching)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# ============================================================================
# Search Configuration
# ============================================================================
# How often to run searches (in hours)
SEARCH_INTERVAL_HOURS=2

# Maximum number of searches to run concurrently
MAX_CONCURRENT_SEARCHES=5

# Default matching threshold (0-100%)
MATCH_THRESHOLD_DEFAULT=70.0

# Maximum results to fetch per platform
MAX_RESULTS_PER_PLATFORM=20

# Search operation timeout (in seconds)
SEARCH_TIMEOUT_SECONDS=300

# ============================================================================
# Scraper Settings
# ============================================================================

# Craigslist Configuration
CRAIGSLIST_DEFAULT_CITY=boston
CRAIGSLIST_RATE_LIMIT=10

# Facebook Marketplace Configuration
FACEBOOK_RATE_LIMIT=5

# eBay Configuration
EBAY_RATE_LIMIT=10

# ============================================================================
# Selenium Configuration (for Facebook Marketplace)
# ============================================================================
SELENIUM_HEADLESS=true
SELENIUM_TIMEOUT=30
SELENIUM_IMPLICIT_WAIT=10

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ============================================================================
# CORS Settings
# ============================================================================
# Comma-separated list of allowed origins
# Development: Use localhost URLs
# Production: Add your deployed frontend URL
# Example: CORS_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ============================================================================
# WebSocket Settings
# ============================================================================
WEBSOCKET_HEARTBEAT_INTERVAL=30
WEBSOCKET_MAX_CONNECTIONS=100

# ============================================================================
# Email Notification Settings
# ============================================================================
ENABLE_EMAIL_NOTIFICATIONS=true

# Email Provider Selection
# Options: 'smtp', 'http' (for SendGrid/Mailgun), or 'auto' (auto-detect)
# Recommended: 'http' for production (Render.com, etc.)
EMAIL_PROVIDER=http

# ============================================================================
# SendGrid Configuration (Recommended for Production)
# ============================================================================
# Get your API key from: https://app.sendgrid.com/settings/api_keys
# Free tier: 100 emails/day
SENDGRID_API_KEY=

# ============================================================================
# Mailgun Configuration (Alternative to SendGrid)
# ============================================================================
# Get your API key from: https://app.mailgun.com/app/account/security/api_keys
# Free tier: 5,000 emails/month for 3 months
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ============================================================================
# SMTP Configuration (Legacy - for local development only)
# ============================================================================
# Note: SMTP often doesn't work on cloud platforms like Render.com
# Use SendGrid or Mailgun instead for production
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ============================================================================
# Common Email Settings
# ============================================================================
EMAIL_FROM=your-email@example.com
EMAIL_FROM_NAME=Product Search Agent

# Time to send daily digest (HH:MM format, 24-hour)
EMAIL_DAILY_DIGEST_TIME=09:00

# Email retry settings
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY=2.0
EMAIL_TIMEOUT=90

# ============================================================================
# Monitoring & Logging
# ============================================================================
# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Enable metrics collection
ENABLE_METRICS=false

# ============================================================================
# Development vs Production Settings
# ============================================================================

# Development (default)
# - DEBUG=true
# - LOG_LEVEL=DEBUG
# - DATABASE_ECHO=true
# - RELOAD=true
# - SELENIUM_HEADLESS=false (to see browser)

# Production
# - DEBUG=false
# - LOG_LEVEL=INFO
# - DATABASE_ECHO=false
# - RELOAD=false
# - SELENIUM_HEADLESS=true
# - Use PostgreSQL instead of SQLite
# - Set strong CORS_ORIGINS
# - Enable SENTRY_DSN for error tracking

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
LLM_ENABLED=true
LLM_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT=30
